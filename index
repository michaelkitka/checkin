
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>First Choice — Weekly Check-In</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #0e0e0e;
  --bg2: #161616;
  --bg3: #1e1e1e;
  --border: rgba(255,255,255,0.08);
  --border-hover: rgba(255,255,255,0.18);
  --text: #f0f0ee;
  --text-muted: #888;
  --text-dim: #555;
  --accent: #f0f0ee;
  --accent-bg: rgba(240,240,238,0.07);
  --accent-border: rgba(240,240,238,0.25);
  --danger: #e05252;
  --danger-bg: rgba(224,82,82,0.1);
  --success-bg: rgba(52,211,153,0.1);
  --success: #34d399;
  --warning: #fbbf24;
  --warning-bg: rgba(251,191,36,0.1);
  --radius: 10px;
  --radius-lg: 14px;
}

html { background: var(--bg); }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

.app { max-width: 620px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }

.screen { display: none; }
.screen.active { display: block; }

.logo {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 15px;
  letter-spacing: 0.15em;
  color: var(--text);
  text-transform: uppercase;
  margin-bottom: 2.5rem;
  opacity: 0.9;
}

h1 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 36px;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--text);
  margin-bottom: 0.4rem;
  line-height: 1.1;
}

.sub {
  font-size: 15px;
  color: var(--text-muted);
  margin-bottom: 2rem;
  line-height: 1.6;
}

.field { margin-bottom: 1.5rem; }

label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.07em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

input[type=text],
input[type=password],
textarea {
  width: 100%;
  padding: 11px 14px;
  font-size: 15px;
  font-family: 'DM Sans', sans-serif;
  background: var(--bg2);
  border: 0.5px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  transition: border-color 0.15s;
  outline: none;
}
input[type=text]:focus,
input[type=password]:focus,
textarea:focus { border-color: var(--border-hover); }
input::placeholder, textarea::placeholder { color: var(--text-dim); }
textarea { resize: vertical; min-height: 80px; }

.scale-row { display: flex; gap: 6px; flex-wrap: wrap; }
.scale-btn {
  width: 42px; height: 42px;
  border-radius: var(--radius);
  border: 0.5px solid var(--border);
  background: var(--bg2);
  color: var(--text-muted);
  font-size: 14px;
  font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  cursor: pointer;
  transition: all 0.12s;
}
.scale-btn:hover { border-color: var(--border-hover); color: var(--text); }
.scale-btn.selected {
  background: var(--text);
  border-color: var(--text);
  color: var(--bg);
  font-weight: 700;
}

.mc-option {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border: 0.5px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 6px;
  cursor: pointer;
  background: var(--bg2);
  transition: all 0.12s;
}
.mc-option:hover { border-color: var(--border-hover); }
.mc-option.selected {
  background: var(--accent-bg);
  border-color: var(--accent-border);
}
.mc-radio {
  width: 16px; height: 16px;
  border-radius: 50%;
  border: 1.5px solid var(--text-dim);
  flex-shrink: 0;
  transition: all 0.12s;
}
.mc-option.selected .mc-radio {
  background: var(--text);
  border-color: var(--text);
}
.mc-label { font-size: 14px; color: var(--text-muted); }
.mc-option.selected .mc-label { color: var(--text); }

.btn-primary {
  width: 100%;
  padding: 13px;
  font-size: 15px;
  font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  background: var(--text);
  color: var(--bg);
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  margin-top: 1rem;
  transition: opacity 0.15s;
  letter-spacing: 0.01em;
}
.btn-primary:hover { opacity: 0.88; }
.btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }

.btn-secondary {
  padding: 9px 18px;
  font-size: 14px;
  font-weight: 500;
  font-family: 'DM Sans', sans-serif;
  background: transparent;
  color: var(--text-muted);
  border: 0.5px solid var(--border);
  border-radius: var(--radius);
  cursor: pointer;
  transition: all 0.12s;
}
.btn-secondary:hover { border-color: var(--border-hover); color: var(--text); }

.back-btn {
  font-size: 13px;
  color: var(--text-dim);
  cursor: pointer;
  margin-bottom: 2rem;
  display: inline-block;
  transition: color 0.12s;
}
.back-btn:hover { color: var(--text-muted); }

.divider { height: 0.5px; background: var(--border); margin: 2rem 0; }

.name-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: 8px;
  margin-bottom: 1.5rem;
}
.name-chip {
  padding: 11px 14px;
  border-radius: var(--radius);
  border: 0.5px solid var(--border);
  background: var(--bg2);
  font-size: 14px;
  font-weight: 500;
  color: var(--text-muted);
  cursor: pointer;
  text-align: center;
  transition: all 0.12s;
}
.name-chip:hover { border-color: var(--border-hover); color: var(--text); }

.client-card {
  border: 0.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1rem 1.25rem;
  background: var(--bg2);
  margin-bottom: 8px;
  cursor: pointer;
  transition: border-color 0.12s;
}
.client-card:hover { border-color: var(--border-hover); }

.client-name { font-size: 15px; font-weight: 500; color: var(--text); }
.client-meta { font-size: 12px; color: var(--text-muted); margin-top: 4px; }

.tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 500;
  padding: 3px 9px;
  border-radius: 20px;
  margin-right: 6px;
  letter-spacing: 0.03em;
}
.tag-low { background: var(--danger-bg); color: var(--danger); }
.tag-mid { background: var(--warning-bg); color: var(--warning); }
.tag-high { background: var(--success-bg); color: var(--success); }
.tag-none { background: var(--bg3); color: var(--text-dim); }

.history-entry {
  border: 0.5px solid var(--border);
  border-radius: var(--radius);
  padding: 1rem 1.25rem;
  background: var(--bg2);
  margin-bottom: 8px;
}
.entry-date { font-size: 11px; color: var(--text-dim); margin-bottom: 10px; letter-spacing: 0.04em; text-transform: uppercase; }
.entry-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 7px;
  gap: 12px;
}
.entry-label { font-size: 12px; color: var(--text-muted); flex-shrink: 0; }
.entry-val { font-size: 13px; font-weight: 500; color: var(--text); text-align: right; }
.score-pill {
  display: inline-block;
  font-size: 12px;
  font-weight: 500;
  padding: 2px 9px;
  border-radius: 20px;
}

.alert {
  padding: 10px 14px;
  border-radius: var(--radius);
  font-size: 13px;
  margin-bottom: 1rem;
}
.alert-danger { background: var(--danger-bg); color: var(--danger); border: 0.5px solid rgba(224,82,82,0.2); }
.alert-success { background: var(--success-bg); color: var(--success); border: 0.5px solid rgba(52,211,153,0.2); }

.add-row { display: flex; gap: 8px; }
.add-row input { flex: 1; }

.coach-row { display: flex; gap: 8px; }
.coach-row input { flex: 1; }

.empty-state {
  text-align: center;
  padding: 3rem 1rem;
  color: var(--text-dim);
  font-size: 14px;
}

.loading { color: var(--text-dim); font-size: 14px; padding: 1rem 0; }

.check-number {
  display: inline-block;
  font-size: 11px;
  font-weight: 500;
  color: var(--text-dim);
  background: var(--bg3);
  padding: 2px 8px;
  border-radius: 20px;
  margin-left: 8px;
  letter-spacing: 0.04em;
}

@media (max-width: 480px) {
  .scale-btn { width: 36px; height: 36px; font-size: 13px; }
  h1 { font-size: 28px; }
}
</style>
</head>
<body>
<div class="app">

<!-- HOME -->
<div id="home" class="screen active">
  <div class="logo">First Choice</div>
  <h1>Weekly Check-In</h1>
  <p class="sub">Enter your full name to get started.</p>
  <div class="add-row">
    <input type="text" id="new-name-input" placeholder="Your full name..." onkeydown="if(event.key==='Enter')addClient()" />
    <button class="btn-secondary" onclick="addClient()">Start</button>
  </div>
  <div class="divider"></div>
  <div style="text-align:center;">
    <button class="btn-secondary" onclick="show('coach-login')">Coach view</button>
  </div>
</div>

<!-- CHECK-IN FORM -->
<div id="checkin" class="screen">
  <div class="logo">First Choice</div>
  <span class="back-btn" onclick="goHome()">← Back</span>
  <h1 id="checkin-title">Check-In</h1>
  <p class="sub">Fill this out before your call this week.</p>

  <div class="field">
    <label>1. How confident do you feel about your progress this week?</label>
    <div class="scale-row" id="scale-confidence"></div>
  </div>
  <div class="field">
    <label>2. What is the biggest thing you are stuck on right now?</label>
    <div id="mc-stuck">
      <div class="mc-option" onclick="selectMC('stuck',this,'Coming up with content ideas')"><div class="mc-radio"></div><span class="mc-label">Coming up with content ideas</span></div>
      <div class="mc-option" onclick="selectMC('stuck',this,'Getting content to convert to DMs or leads')"><div class="mc-radio"></div><span class="mc-label">Getting content to convert to DMs or leads</span></div>
      <div class="mc-option" onclick="selectMC('stuck',this,'Booking qualified sales calls')"><div class="mc-radio"></div><span class="mc-label">Booking qualified sales calls</span></div>
      <div class="mc-option" onclick="selectMC('stuck',this,'Closing deals on calls')"><div class="mc-radio"></div><span class="mc-label">Closing deals on calls</span></div>
      <div class="mc-option" onclick="selectMC('stuck',this,'Staying consistent with posting')"><div class="mc-radio"></div><span class="mc-label">Staying consistent with posting</span></div>
      <div class="mc-option" onclick="selectMC('stuck',this,'Something else')"><div class="mc-radio"></div><span class="mc-label">Something else</span></div>
    </div>
  </div>
  <div class="field">
    <label>3. Describe it or give more detail (optional)</label>
    <textarea id="ans-detail" placeholder="What's going on..."></textarea>
  </div>
  <div class="field">
    <label>4. How many pieces of content did you post this week?</label>
    <input type="text" id="ans-content" placeholder="e.g. 5" />
  </div>
  <div class="field">
    <label>5. How many sales calls did you book or take this week?</label>
    <input type="text" id="ans-calls" placeholder="e.g. 2" />
  </div>
  <div class="field">
    <label>6. Did you complete your outreach activity this week?</label>
    <div id="mc-outreach">
      <div class="mc-option" onclick="selectMC('outreach',this,'Yes')"><div class="mc-radio"></div><span class="mc-label">Yes</span></div>
      <div class="mc-option" onclick="selectMC('outreach',this,'Partially')"><div class="mc-radio"></div><span class="mc-label">Partially</span></div>
      <div class="mc-option" onclick="selectMC('outreach',this,'No')"><div class="mc-radio"></div><span class="mc-label">No</span></div>
    </div>
  </div>
  <div class="field">
    <label>7. How clear are you on what to do next?</label>
    <div class="scale-row" id="scale-clarity"></div>
  </div>
  <div class="field">
    <label>8. What do you need from me most this week?</label>
    <div id="mc-need">
      <div class="mc-option" onclick="selectMC('need',this,'Feedback on my content')"><div class="mc-radio"></div><span class="mc-label">Feedback on my content</span></div>
      <div class="mc-option" onclick="selectMC('need',this,'Help with my sales script or call review')"><div class="mc-radio"></div><span class="mc-label">Help with my sales script or call review</span></div>
      <div class="mc-option" onclick="selectMC('need',this,'Strategy or direction')"><div class="mc-radio"></div><span class="mc-label">Strategy or direction</span></div>
      <div class="mc-option" onclick="selectMC('need',this,'Accountability and a push')"><div class="mc-radio"></div><span class="mc-label">Accountability and a push</span></div>
      <div class="mc-option" onclick="selectMC('need',this,'I am good, just keeping you updated')"><div class="mc-radio"></div><span class="mc-label">I am good, just keeping you updated</span></div>
    </div>
  </div>
  <div class="field">
    <label>9. Anything else you want me to know before our call?</label>
    <textarea id="ans-notes" placeholder="Anything at all..."></textarea>
  </div>
  <div id="checkin-error" class="alert alert-danger" style="display:none;"></div>
  <button class="btn-primary" id="submit-btn" onclick="submitCheckin()">Submit check-in</button>
</div>

<!-- THANKS -->
<div id="thanks" class="screen">
  <div class="logo">First Choice</div>
  <div style="padding: 4rem 0; text-align:center;">
    <div style="font-size:48px;margin-bottom:1.5rem;">✓</div>
    <h1 style="margin-bottom:0.5rem;">Done.</h1>
    <p class="sub" style="margin-bottom:2rem;">Michael will review this before your call.</p>
    <button class="btn-secondary" onclick="goHome()">Back to home</button>
  </div>
</div>

<!-- COACH LOGIN -->
<div id="coach-login" class="screen">
  <div class="logo">First Choice</div>
  <span class="back-btn" onclick="goHome()">← Back</span>
  <h1>Coach view</h1>
  <p class="sub">Enter your password to access client responses.</p>
  <div class="field">
    <label>Password</label>
    <div class="coach-row">
      <input type="password" id="pw-input" placeholder="Password..." onkeydown="if(event.key==='Enter')checkPw()" />
      <button class="btn-secondary" onclick="checkPw()">Enter</button>
    </div>
  </div>
  <div id="pw-error" class="alert alert-danger" style="display:none;">Wrong password. Try again.</div>
</div>

<!-- COACH DASHBOARD -->
<div id="coach-dash" class="screen">
  <div class="logo">First Choice</div>
  <span class="back-btn" onclick="goHome()">← Sign out</span>
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:8px;">
    <h1>Clients</h1>
    <span id="submission-count" style="font-size:13px;color:var(--text-dim);"></span>
  </div>
  <div id="coach-list"></div>
</div>

<!-- CLIENT HISTORY -->
<div id="client-history" class="screen">
  <div class="logo">First Choice</div>
  <span class="back-btn" onclick="showDash()">← All clients</span>
  <h1 id="history-name" style="display:inline;"></h1>
  <span id="history-badge" class="check-number"></span>
  <p id="history-count" class="sub" style="margin-top:0.5rem;"></p>
  <div id="history-entries"></div>
</div>

</div>

<script>
let coachPassword = null;
let state = { currentClient: null, answers: {}, scales: {} };

function show(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

async function goHome() {
  coachPassword = null;
  document.getElementById('new-name-input').value = '';
  show('home');
}

async function addClient() {
  const input = document.getElementById('new-name-input');
  const name = input.value.trim();
  if (!name) return;
  try {
    await fetch('/api/clients', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name })
    });
    input.value = '';
    startCheckin(name);
  } catch(e) {
    alert('Could not add client. Try again.');
  }
}

function buildScale(id, key) {
  const el = document.getElementById(id);
  el.innerHTML = '';
  for (let i = 1; i <= 10; i++) {
    const b = document.createElement('button');
    b.className = 'scale-btn';
    b.textContent = i;
    b.onclick = () => {
      el.querySelectorAll('.scale-btn').forEach(x => x.classList.remove('selected'));
      b.classList.add('selected');
      state.scales[key] = i;
    };
    el.appendChild(b);
  }
}

function selectMC(key, el, val) {
  el.closest('[id^="mc-"]').querySelectorAll('.mc-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  state.answers[key] = val;
}

function startCheckin(name) {
  state.currentClient = name;
  state.answers = {};
  state.scales = {};
  document.getElementById('checkin-title').textContent = 'Hey ' + name.split(' ')[0];
  document.querySelectorAll('.mc-option').forEach(o => o.classList.remove('selected'));
  ['ans-detail','ans-content','ans-calls','ans-notes'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('checkin-error').style.display = 'none';
  document.getElementById('submit-btn').disabled = false;
  buildScale('scale-confidence', 'confidence');
  buildScale('scale-clarity', 'clarity');
  show('checkin');
}

async function submitCheckin() {
  const err = document.getElementById('checkin-error');
  const btn = document.getElementById('submit-btn');
  if (!state.scales.confidence) { err.textContent = 'Please rate your confidence.'; err.style.display='block'; return; }
  if (!state.answers.stuck) { err.textContent = 'Please select what you are stuck on.'; err.style.display='block'; return; }
  if (!state.scales.clarity) { err.textContent = 'Please rate how clear you are on next steps.'; err.style.display='block'; return; }
  if (!state.answers.need) { err.textContent = 'Please select what you need from Michael this week.'; err.style.display='block'; return; }
  err.style.display = 'none';
  btn.disabled = true;
  btn.textContent = 'Submitting...';

  try {
    const res = await fetch('/api/checkins', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        client_name: state.currentClient,
        confidence: state.scales.confidence,
        stuck_on: state.answers.stuck,
        detail: document.getElementById('ans-detail').value.trim(),
        content_posts: document.getElementById('ans-content').value.trim(),
        sales_calls: document.getElementById('ans-calls').value.trim(),
        outreach: state.answers.outreach || null,
        clarity: state.scales.clarity,
        needs_from_coach: state.answers.need,
        notes: document.getElementById('ans-notes').value.trim()
      })
    });
    if (!res.ok) throw new Error('Failed');
    show('thanks');
  } catch(e) {
    err.textContent = 'Something went wrong. Try again.';
    err.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Submit check-in';
  }
}

async function checkPw() {
  const val = document.getElementById('pw-input').value;
  const errEl = document.getElementById('pw-error');
  try {
    const res = await fetch('/api/coach/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: val })
    });
    if (res.ok) {
      coachPassword = val;
      document.getElementById('pw-input').value = '';
      errEl.style.display = 'none';
      showDash();
    } else {
      errEl.style.display = 'block';
    }
  } catch(e) {
    errEl.style.display = 'block';
  }
}

async function showDash() {
  show('coach-dash');
  const list = document.getElementById('coach-list');
  list.innerHTML = '<div class="loading">Loading...</div>';

  try {
    const [clientsRes, checkinsRes] = await Promise.all([
      fetch('/api/clients'),
      fetch('/api/coach/checkins', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: coachPassword })
      })
    ]);
    const clients = await clientsRes.json();
    const checkins = await checkinsRes.json();

    const grouped = {};
    checkins.forEach(e => {
      if (!grouped[e.client_name]) grouped[e.client_name] = [];
      grouped[e.client_name].push(e);
    });

    const allNames = [...new Set([...clients.map(c => c.name), ...Object.keys(grouped)])].sort();
    document.getElementById('submission-count').textContent = checkins.length + ' total submissions';

    if (!allNames.length) {
      list.innerHTML = '<div class="empty-state">No clients yet.</div>';
      return;
    }

    list.innerHTML = allNames.map(name => {
      const entries = grouped[name] || [];
      const latest = entries[0];
      const conf = latest ? latest.confidence : null;
      const tagClass = conf ? (conf <= 4 ? 'tag-low' : conf <= 7 ? 'tag-mid' : 'tag-high') : 'tag-none';
      const tagText = conf ? 'Confidence ' + conf + '/10' : 'No check-ins';
      const stuckText = latest ? latest.stuck_on : '';
      const dateText = latest ? new Date(latest.submitted_at).toLocaleDateString('en-CA', {month:'short',day:'numeric'}) : '';
      return `<div class="client-card" onclick="showClientHistory('${name.replace(/'/g,"\\'")}')">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <div class="client-name">${name}</div>
          <span class="tag ${tagClass}">${tagText}</span>
        </div>
        <div class="client-meta" style="margin-top:6px;">${stuckText ? 'Stuck: ' + stuckText : ''}</div>
        <div class="client-meta">${entries.length} check-in${entries.length !== 1 ? 's' : ''}${dateText ? ' · Last ' + dateText : ''}</div>
      </div>`;
    }).join('');
  } catch(e) {
    list.innerHTML = '<div class="empty-state">Could not load data.</div>';
  }
}

async function showClientHistory(name) {
  show('client-history');
  document.getElementById('history-name').textContent = name;
  document.getElementById('history-badge').textContent = '';
  document.getElementById('history-count').textContent = '';
  const container = document.getElementById('history-entries');
  container.innerHTML = '<div class="loading">Loading...</div>';

  try {
    const res = await fetch('/api/coach/checkins', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: coachPassword, client_name: name })
    });
    const entries = await res.json();
    document.getElementById('history-badge').textContent = entries.length + ' check-in' + (entries.length !== 1 ? 's' : '');
    document.getElementById('history-count').textContent = '';

    if (!entries.length) {
      container.innerHTML = '<div class="empty-state">No check-ins yet.</div>';
      return;
    }

    container.innerHTML = entries.map((e, i) => {
      const d = new Date(e.submitted_at);
      const confClass = e.confidence <= 4 ? 'tag-low' : e.confidence <= 7 ? 'tag-mid' : 'tag-high';
      const clarClass = e.clarity <= 4 ? 'tag-low' : e.clarity <= 7 ? 'tag-mid' : 'tag-high';
      return `<div class="history-entry">
        <div class="entry-date">Check-in ${entries.length - i} &nbsp;·&nbsp; ${d.toLocaleDateString('en-CA', {weekday:'short',month:'short',day:'numeric',year:'numeric'})}</div>
        <div class="entry-row"><span class="entry-label">Confidence</span><span class="score-pill ${confClass}">${e.confidence}/10</span></div>
        <div class="entry-row"><span class="entry-label">Clarity on next steps</span><span class="score-pill ${clarClass}">${e.clarity}/10</span></div>
        <div class="entry-row"><span class="entry-label">Stuck on</span><span class="entry-val">${e.stuck_on}</span></div>
        ${e.detail ? `<div class="entry-row"><span class="entry-label">Detail</span><span class="entry-val">${e.detail}</span></div>` : ''}
        <div class="entry-row"><span class="entry-label">Content posted</span><span class="entry-val">${e.content_posts || 'n/a'}</span></div>
        <div class="entry-row"><span class="entry-label">Sales calls</span><span class="entry-val">${e.sales_calls || 'n/a'}</span></div>
        <div class="entry-row"><span class="entry-label">Outreach done</span><span class="entry-val">${e.outreach || 'n/a'}</span></div>
        <div class="entry-row"><span class="entry-label">Needs from Michael</span><span class="entry-val">${e.needs_from_coach}</span></div>
        ${e.notes ? `<div class="entry-row"><span class="entry-label">Notes</span><span class="entry-val">${e.notes}</span></div>` : ''}
      </div>`;
    }).join('');
  } catch(e) {
    container.innerHTML = '<div class="empty-state">Could not load history.</div>';
  }
}
</script>
</body>
</html>
